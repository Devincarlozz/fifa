# RIT FIFA World Cup 2026 Predictor — Configuration Template
# Copy this file to '.env' and fill in your details to enable real Firebase features.
# If these variables are not set, the app runs in a Sandbox Mode using local storage!

# Firebase Project Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Football Data API Key (football-data.org)
VITE_FOOTBALL_DATA_API_KEY=your_football_data_api_key

# Admin Credentials for script execution
ADMIN_EMAIL=your_admin_email
ADMIN_PASSWORD=your_admin_password
