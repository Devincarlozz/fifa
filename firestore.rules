rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the requester an authenticated administrator?
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == 'admin@rit.ac.in' ||
          request.auth.token.email.lower() == 'bhagathkrishnan06@gmail.com' ||
          request.auth.token.email.lower() == '24bb16641@rit.ac.in'
        )) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'))
      );
    }

    // Helper: Is the requester the owner of this user record?
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper: Get user's active status from their user document
    function isUserActive() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    // Helper: Check if match kickoff has passed
    function isMatchKickedOff(matchId) {
      return false; // TEMPORARY EMERGENCY BYPASS
    }

    // Helper: Check if match has ended (to allow other users to inspect predictions)
    function isMatchFinished(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data.status == 'FINISHED';
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Any authenticated user can view player leaderboard profile details
      allow read: if request.auth != null;
      // Users can only write/update their own profile (preventing privilege escalation)
      allow create: if isOwner(userId) 
        && request.resource.data.isActive == true
        && (
          (!request.resource.data.keys().hasAny(['isAdmin', 'role']))
          || (
            (request.resource.data.isAdmin == false || !request.resource.data.keys().hasAny(['isAdmin']))
            && (request.resource.data.role != 'admin' || !request.resource.data.keys().hasAny(['role']))
          )
          || request.auth.token.admin == true
        );

      allow update: if isOwner(userId) 
        && request.resource.data.isActive == resource.data.isActive // users can't reactive themselves if suspended
        && request.resource.data.totalPoints == resource.data.totalPoints // users can't edit their points
        && request.resource.data.predictionsCount == resource.data.predictionsCount // users can't edit their counts
        && (!request.resource.data.keys().hasAny(['dreamTeamPoints']) || request.resource.data.dreamTeamPoints == resource.data.dreamTeamPoints)
        && (
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'role']))
          || request.auth.token.admin == true
        );
      allow write: if isAdmin();
    }

    // --- Matches Collection ---
    match /matches/{matchId} {
      // Anyone logged in can check match schedules and live scores
      allow read: if request.auth != null;
      // Only admins can write, edit schedule, or confirm match outcomes
      allow write: if isAdmin();
    }

    // --- Predictions Collection ---
    match /predictions/{predId} {
      // Users can read their own predictions. 
      // Other players can only read this prediction after the match has finished (to prevent copycatting).
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.userId || 
        isAdmin() || 
        isMatchFinished(resource.data.matchId)
      );

      // Users can write predictions under strict conditions:
      allow create: if request.auth != null
        // 1. Must be the owner of the prediction
        && request.resource.data.userId == request.auth.uid
        // 2. The player account must be active (not suspended)
        && isUserActive()
        // 3. Kickoff time must NOT have passed
        && !isMatchKickedOff(request.resource.data.matchId)
        // 4. Regular users cannot submit points on creation
        && !request.resource.data.keys().hasAny(['pointsEarned', 'pointsBreakdown', 'pointsAwardedAt']);

      allow update: if request.auth != null
        // 1. Must be the owner of the prediction
        && request.resource.data.userId == request.auth.uid
        && resource.data.userId == request.auth.uid
        // 2. The player account must be active (not suspended)
        && isUserActive()
        // 3. Kickoff time must NOT have passed
        && !isMatchKickedOff(request.resource.data.matchId)
        // 4. Regular users cannot manipulate points fields
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['pointsEarned', 'pointsBreakdown', 'pointsAwardedAt']);

      // Only admins can delete or award points on predictions
      allow delete, write: if isAdmin();
    }

    // --- Awards Predictions Collection ---
    match /awards_predictions/{userId} {
      allow read: if request.auth != null && (isOwner(userId) || isAdmin());
      allow create, update: if request.auth != null && isOwner(userId);
      allow write: if isAdmin();
    }

    // --- Admin Results Collection ---
    match /adminResults/{matchId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Leaderboard Collection ---
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Dream Teams Collection ---
    match /dream_teams/{userId} {
      allow read: if request.auth != null && (
        isOwner(userId) ||
        isAdmin() ||
        (exists(/databases/$(database)/documents/matches/wc2026_001) && request.time >= get(/databases/$(database)/documents/matches/wc2026_001).data.kickoffTime)
      );
      // Allow any authenticated owner to save their dream team before tournament kickoff
      // Removed isUserActive() check — users without isActive set should still be allowed
      allow create, update: if request.auth != null && isOwner(userId)
        && (!exists(/databases/$(database)/documents/matches/wc2026_001) || request.time < get(/databases/$(database)/documents/matches/wc2026_001).data.kickoffTime)
        && !request.resource.data.keys().hasAny(['pointsEarned', 'pointsBreakdown', 'pointsAwardedAt']);
      allow write: if isAdmin();
    }

    // --- Custom Players Collection ---
    match /custom_players/{playerId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- System / Settings Collection ---
    match /system/{documentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
